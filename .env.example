# Local demo configuration template (safe to commit).
#
# start-fresh.sh / start-fresh.ps1 copy this file to .env automatically when
# .env is missing — evaluators can run ./start-fresh.sh with no manual setup.
#
# .env is gitignored. Do not commit real secrets. Override ports or passwords
# in your local .env as needed; values below are demo defaults only.

DOWNLOAD_SERVICE_PORT=8030
DOWNLOAD_SERVICE_BASE_URL=http://localhost:${DOWNLOAD_SERVICE_PORT}

TEST_CLIENT_PORT=8031

MANAGEMENT_SERVICE_PORT=8131

MAX_FILE_SIZE_MB=5
RATE_LIMIT_REQUESTS_PER_MINUTE=5

OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_BATCH_SIZE=5

# Monitoring
PROMETHEUS_PORT=8271
GRAFANA_PORT=8272
GRAFANA_ADMIN_PASSWORD=changeme

# PostgreSQL
DB_PORT=8231
DB_NAME=secure_download_system
DB_USER=db_app_user
DB_PASSWORD=changeme

# Kafka
KAFKA_UI_PORT=8241

# Keycloak
KEYCLOAK_PORT=8251
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Keycloak Clients (local demo secrets — not production credentials)
SDS_DOWNLOAD_CLIENT_SECRET=change-me-sds-download-client-secret
SDS_SAMPLE_CLIENT_SECRET=changeme

# MinIO
MINIO_REGION=us-east-1
MINIO_PORT=8261
MINIO_CONSOLE_PORT=8262
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme
MINIO_DOCUMENTS_BUCKET=documents
MINIO_ARCHIVE_BUCKET=archive

# Kafka Connect
KAFKA_CONNECT_PORT=8281
